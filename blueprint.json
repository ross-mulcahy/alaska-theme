{
	"landingPage": "/",
	"preferredVersions": {
		"php": "8.2",
		"wp": "latest"
	},
	"features": {
		"networking": true
	},
	"steps": [
		{
			"step": "installTheme",
			"themeData": {
				"resource": "url",
				"url": "https://github-proxy.com/proxy.php?repo=ross-mulcahy/alaska-theme&branch=main"
			},
			"options": {
				"activate": true
			}
		},
		{
			"step": "setSiteOptions",
			"options": {
				"blogname": "Alaska Airlines",
				"blogdescription": "The Elevated Voyager",
				"permalink_structure": "/%postname%/"
			}
		}
	]
}
